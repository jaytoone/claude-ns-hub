#!/bin/bash
# wsl-unexpose <port> — remove localhost:<port> mirror from every online Windows tailnet client.
set -e
port="$1"
if [ -z "$port" ] || ! [[ "$port" =~ ^[0-9]+$ ]]; then
    echo "Usage: wsl-unexpose <port>" >&2
    exit 1
fi

payload="{\"port\":${port}}"
notify_token=$(cat "$HOME/.claude/.notify-secret" 2>/dev/null || echo "")
while read -r ip host; do
    [ -z "$ip" ] && continue
    if curl -sf -m 3 -X POST "http://${ip}:6789/unexpose" \
         -H 'Content-Type: application/json' \
         -H "X-Notify-Token: ${notify_token}" \
         --data "$payload" >/dev/null 2>&1; then
        echo "✓ unexposed port $port on $host ($ip)"
    else
        echo "✗ skipped $host ($ip)"
    fi
done < <(tailscale status --json 2>/dev/null | jq -r '.Peer[] | select(.Online==true and (.OS=="windows")) | .TailscaleIPs[0] + " " + .HostName' 2>/dev/null)
